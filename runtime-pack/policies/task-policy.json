{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "name": "task-policy",
  "version": "1.0.0",
  "maxPlanSteps": 20,
  "maxTotalCommands": 100,
  "maxCheckpoints": 20,
  "allowedTaskModes": [
    "bug-fix",
    "feature",
    "refactor",
    "test",
    "documentation",
    "ci",
    "maintenance",
    "pr-repair",
    "repository-audit",
    "daily-improvement"
  ]
}
