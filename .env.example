# Controller Master Credentials
E2B_API_KEY=e2b_sec_...
MCP_ACCESS_TOKEN=your_mcp_access_token_here

# Controller HTTP Server & Worker Timeouts
CONTROLLER_PORT=3000
WORKER_DEFAULT_TIMEOUT_MS=600000
WORKER_MAX_TIMEOUT_MS=3600000
MAX_ACTIVE_WORKERS=3
COMMAND_DEFAULT_TIMEOUT_MS=60000
COMMAND_MAX_TIMEOUT_MS=300000
COMMAND_OUTPUT_LIMIT_BYTES=131072
SESSION_REGISTRY_PATH=.data/sessions.json

# Phase 3: GitHub App Publishing Credentials (Controller Only)
GITHUB_APP_ID=123456
GITHUB_APP_INSTALLATION_ID=789012
GITHUB_APP_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# GITHUB_APP_PRIVATE_KEY_BASE64=

# GitHub Policy & Allowlists (Optional)
GITHUB_ALLOWED_REPOSITORIES=owner/repo1,owner/repo2
GITHUB_ALLOWED_OWNERS=owner1,owner2
GITHUB_DEFAULT_BRANCH_PREFIX=agent/
GITHUB_TOKEN_REFRESH_SKEW_SECONDS=300
GITHUB_API_BASE_URL=https://api.github.com

# Integration Testing (Optional)
# GITHUB_INTEGRATION_TEST_REPOSITORY=owner/test-repo
# GITHUB_INTEGRATION_TEST_ALLOW_PUSH=true
